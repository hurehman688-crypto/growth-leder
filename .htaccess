# ============================================================
# Growth Leder — .htaccess
# Optimized for StackCP / Apache (Static HTML Site)
# Last updated: 2026-04-05
# ============================================================

# ── Directory Security ───────────────────────────────────────
Options -Indexes -MultiViews
ServerSignature Off

# Block access to sensitive files
<FilesMatch "(^\.htaccess|^\.env|^\.git|composer\.(json|lock)|package(-lock)?\.json|tailwind\.config\.js|recover_content\.py|reconstruct_pages\.py|.*\.md|.*_backup|.*_recovered.*)$">
  Require all denied
</FilesMatch>

# ── Custom Error Pages ────────────────────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html
ErrorDocument 500 /404.html

# ── URL Rewrites & Redirects ──────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force HTTPS (only if SSL is actually available)
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Force non-www → www removed (growthleder.com is canonical non-www)
  # If you want www → non-www, uncomment:
  # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  # RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # 3. Redirect .html extension to clean URL (strip .html → trailing slash)
  RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]

  # 4. Ensure trailing slash for directories
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # 5. Serve index.html from folder (clean URLs)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]

  # 6. Internal rewrite — clean URL to .html file
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # 7. Block bad bots
  RewriteCond %{HTTP_USER_AGENT} (ahrefsbot|semrushbot|dotbot|rogerbot|mj12bot|blexbot|baiduspider|yandexbot|majestic|proximic) [NC]
  RewriteRule .* - [F,L]

  # 8. Block WordPress exploit probes
  RewriteCond %{REQUEST_URI} (wp-admin|wp-login|xmlrpc\.php|\.git|\.env) [NC]
  RewriteRule .* - [F,L]

</IfModule>

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  # Prevent MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Clickjacking protection
  Header always set X-Frame-Options "SAMEORIGIN"

  # XSS protection (legacy browsers)
  Header always set X-XSS-Protection "1; mode=block"

  # Referrer policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions policy
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # HSTS — only enable AFTER SSL is confirmed working (1 year)
  # IMPORTANT: Comment this out if SSL is not yet fixed on StackCP
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Content Security Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com; frame-src 'none';"

  # CORS for fonts
  <FilesMatch "\.(woff2?|ttf|eot|otf)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  # Remove server fingerprinting
  Header unset X-Powered-By
  Header always unset X-Powered-By

  # Cache-Control Headers
  <FilesMatch "\.(js|css|webp|avif|png|jpg|jpeg|gif|svg|woff2?|ttf|otf|eot|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(xml|json|webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ── MIME Types ───────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType image/webp                    .webp
  AddType image/avif                    .avif
  AddType image/svg+xml                 .svg .svgz
  AddType application/font-woff         .woff
  AddType font/woff2                    .woff2
  AddType application/javascript        .js .mjs
  AddType text/css                      .css
  AddType application/json              .json
  AddType application/manifest+json     .webmanifest
  AddType text/cache-manifest           .appcache
</IfModule>

# ── GZip Compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/manifest+json
  AddOutputFilterByType DEFLATE font/woff2 application/font-woff
  # Don't compress already-compressed formats
  SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif|woff2|gz|zip|rar)$ no-gzip dont-vary
</IfModule>

# ── Browser Caching (Expires) ─────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache
  ExpiresByType text/html                   "access plus 1 hour"

  # Assets — long cache
  ExpiresByType text/css                    "access plus 1 year"
  ExpiresByType application/javascript      "access plus 1 year"
  ExpiresByType image/png                   "access plus 1 year"
  ExpiresByType image/jpeg                  "access plus 1 year"
  ExpiresByType image/gif                   "access plus 1 year"
  ExpiresByType image/svg+xml               "access plus 1 year"
  ExpiresByType image/webp                  "access plus 1 year"
  ExpiresByType image/avif                  "access plus 1 year"
  ExpiresByType image/x-icon                "access plus 1 year"
  ExpiresByType font/woff2                  "access plus 1 year"
  ExpiresByType application/font-woff       "access plus 1 year"

  # Misc
  ExpiresByType application/json            "access plus 0 seconds"
  ExpiresByType application/manifest+json   "access plus 1 week"
  ExpiresByType text/xml                    "access plus 0 seconds"
</IfModule>

# ── ETags ─────────────────────────────────────────────────────
FileETag MTime Size
